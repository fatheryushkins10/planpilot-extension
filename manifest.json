{
  "manifest_version": 3,
  "name": "Roadmap Canvas Sync",
  "version": "1.0.0",
  "description": "Sync your Canvas LMS assignments directly into Roadmap — your AI-powered planner. One click, always up to date.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Roadmap Canvas Sync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://*.eee.uci.edu/*",
    "https://planpilot-backend-9tf1.onrender.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
